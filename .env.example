# 微信公众号配置
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# LLM 配置（Agnes AI）
AGNES_API_KEY=your_agnes_api_key
AGNES_MODEL=agnes-2.0-flash
# 可选：自定义 API base URL（默认 https://apihub.agnes-ai.com/v1）
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# Cloudflare Worker 配置（微信个人推送）
NEWS_WORKER_URL=https://your-worker.your-domain.workers.dev/api/news
NEWS_WORKER_TOKEN=optional-auth-token

# 日报配置
DAILY_TOP_N=15
DAILY_WECHAT_TOP_N=5
DAILY_RSS_TIMEOUT=30
DAILY_LLM_TIMEOUT=30

# GitHub 配置（用于部署）
GITHUB_USERNAME=your_github_username
GITHUB_REPO=your_repo_name
